<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.order_system.order.mapper.OrderMapper">

    <insert id="insertOrder" parameterType="com.order_system.order.model.Order">
        INSERT INTO orders (order_id, user_id, status, total_price)
        VALUES (#{orderId}, #{userId}, #{status}, #{totalPrice})
    </insert>

    <select id="selectOrderById" resultType="com.order_system.order.model.Order">
        SELECT * FROM orders WHERE order_id = #{orderId}
    </select>

</mapper>