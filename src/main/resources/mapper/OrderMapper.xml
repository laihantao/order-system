<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.order_system.order.mapper.OrderMapper">

    <select id="insertOrder" parameterType="com.order_system.order.model.Order">
        INSERT INTO orders (
            order_id,
            user_id,
            status,
            total_price,
            idempotency_key
        )
        VALUES (
            #{orderId},
            #{userId},
            #{status},
            #{totalPrice},
            #{idempotencyKey}
        )
        ON CONFLICT (user_id, idempotency_key)
        DO UPDATE SET
            user_id = orders.user_id
        RETURNING *
    </select>

    <select id="selectOrderById" resultType="java.util.Map">
        SELECT * FROM orders WHERE order_id = #{orderId}
    </select>

    <select id="selectAllOrders" resultType="com.order_system.order.model.Order">
        SELECT * FROM orders
    </select>

</mapper>