<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.order_system.food.mapper.FoodMapper">

    <select id="selectAllFood" parameterType="java.util.Map">
        SELECT * FROM FOOD 
    </select>

    <select id="selectFoodById" parameterType="java.util.Map">
        SELECT * FROM FOOD WHERE id = #{food_id}
    </select>


</mapper>